{
  "name": "ai-transcript-copy",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "lint": "eslint 'src/*.js'",
    "test": "node --test 'test/**/*.mjs'",
    "build": "node build.mjs",
    "check": "pnpm run lint && pnpm run test && pnpm run build",
    "bookmarklet": "node scripts/run-bookmarklet.mjs",
    "verify-gdocs": "node scripts/verify-gdocs.mjs",
    "verify-obsidian": "node scripts/verify-obsidian.mjs",
    "test-bookmarklet": "node scripts/test-bookmarklet.mjs",
    "save-reference": "node scripts/save-reference.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint": "^9",
    "prettier": "^3.8.1",
    "puppeteer-core": "^24.40.0",
    "terser": "^5"
  }
}
